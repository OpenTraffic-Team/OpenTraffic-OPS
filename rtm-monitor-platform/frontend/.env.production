# 页面标题
VITE_APP_TITLE = RTM监控运维平台

# 生产环境配置
VITE_APP_ENV = 'production'

# RTM监控运维平台生产环境（前后端同域部署）
# baseURL 为空表示与前端同域，无需额外前缀
VITE_APP_BASE_API = ''

# WebSocket 基础地址
# 开发环境：/dev-ws-api（走 Vite 代理）
# 生产环境（同域部署）：留空，自动使用当前域名
VITE_APP_WS_BASE_API = ''

# 是否在打包时开启压缩，支持 gzip 和 brotli
VITE_BUILD_COMPRESS = gzip