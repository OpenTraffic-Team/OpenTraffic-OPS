# Redis 配置模板
# 镜像地址
image: redis:7-alpine

# 版本
version: 7-alpine

# 端口配置
port: 6379

# 环境变量
env:
  REDIS_PASSWORD: your_redis_password_here

# 数据卷
volumes:
  - redisdata:/data

# 网络配置
network: rtm-network

# 资源限制
resources:
  memory: 256M
  cpu: 0.3

# 命令参数
command: redis-server --requirepass ${REDIS_PASSWORD}
